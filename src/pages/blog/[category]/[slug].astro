---
import { getCollection } from 'astro:content';
import BlogSidebar from '../../../components/BlogSidebar.astro';
import RelatedPosts from '../../../components/RelatedPosts.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { formatDate, getCategoryUrl, getPostUrl, getRelatedPosts, sortPosts, type BlogEntry } from '../../../lib/blog';

export async function getStaticPaths() {
  const posts = sortPosts(await getCollection('blog'));

  return posts.map((entry) => ({
    params: {
      category: entry.data.category,
      slug: entry.slug,
    },
    props: {
      entry,
      allPosts: posts,
    },
  }));
}

interface Props {
  entry: BlogEntry;
  allPosts: BlogEntry[];
}

const { entry, allPosts } = Astro.props;
const relatedPosts = getRelatedPosts(allPosts, entry);
const { Content } = await entry.render();
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  canonicalPath={getPostUrl(entry)}
  pageType="article"
>
  <div class="article-layout">
    <article class="article-shell">
      <nav aria-label="Breadcrumb">
        <ul class="breadcrumbs">
          <li><a href="/">Home</a></li>
          <li><a href="/blog.html">Blog</a></li>
          <li><a href={getCategoryUrl(entry.data.category)}>{entry.data.category}</a></li>
        </ul>
      </nav>

      <header>
        <p class="section-note">Target repo: {entry.data.target_repo}</p>
        <h1 class="article-title">{entry.data.title}</h1>
        <ul class="article-meta">
          <li>{formatDate(entry.data.date)}</li>
          <li>{entry.data.category}</li>
        </ul>
        <div class="tag-list">
          {entry.data.tags.map((tag) => <span class="tag">#{tag}</span>)}
        </div>
        <p class="article-excerpt">{entry.data.description}</p>
      </header>

      <Content />

      <RelatedPosts posts={relatedPosts} />
    </article>

    <BlogSidebar posts={allPosts} currentPost={entry} />
  </div>
</BaseLayout>
