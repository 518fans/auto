---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import { getCategoryUrl, sortPosts, type BlogEntry } from '../../../lib/blog';

export async function getStaticPaths() {
  const posts = sortPosts(await getCollection('blog'));
  const categories = [...new Set(posts.map((post) => post.data.category))];

  return categories.map((category) => ({
    params: { category },
    props: {
      category,
      posts: posts.filter((post) => post.data.category === category),
    },
  }));
}

interface Props {
  category: string;
  posts: BlogEntry[];
}

const { category, posts } = Astro.props;
---

<BaseLayout
  title={`Category: ${category}`}
  description={`Static article archive for ${category}`}
  canonicalPath={getCategoryUrl(category)}
>
  <section class="hero">
    <p class="section-note">Category archive</p>
    <h1 class="page-title">{category}</h1>
    <p class="page-intro">This category archive is included in the sitemap to strengthen topical clustering and crawl paths.</p>
  </section>

  <section class="grid grid--cards">
    {posts.map((post) => <ArticleCard post={post} />)}
  </section>
</BaseLayout>
